<h1><%= @place["name"] %></h1>

<h2>Journal Entries</h2>
<% if @entries.any? %>
  <ul>
    <% @entries.each do |entry| %>
      <li>
        <strong><%= entry["title"] %></strong>: <%= entry["description"] %>
        <br>
        <small>Occurred on: <%= entry["occurred_on"] %></small>
        <% if entry.image.attached? %>
          <br>
          <%= image_tag entry.image, size: "300x300" %>  <!-- Display image here -->
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No entries yet.</p>
<% end %>

<p>
  <%= link_to "Add New Entry", new_entry_path(place_id: @place["id"]) %>
</p>

<a href="/">Back to Places</a>
