<h1>Signup</h1>

<%= form_with model: @user, url: users_path, method: :post do |form| %>
  <div>
    <label>Email</label>
    <%= form.text_field :email %>
  </div>

  <div>
    <label>Password</label>
    <%= form.password_field :password %>
  </div>

  <div>
    <label>Confirm Password</label>
    <%= form.password_field :password_confirmation %>
  </div>

  <div>
    <%= form.submit "Signup" %>
  </div>
<% end %>

