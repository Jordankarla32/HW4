<h1>New Journal Entry for <%= Place.find(params[:place_id]).name %></h1>

<%= form_with model: @entry, url: entries_path, method: :post do |form| %>
  <%= hidden_field_tag :place_id, params[:place_id] %>

  <div>
    <label>Title</label>
    <%= form.text_field :title %>
  </div>

  <div>
    <label>Description</label>
    <%= form.text_area :description %>
  </div>

  <div>
    <label>Occurred On</label>
    <%= form.date_select :occurred_on %>
  </div>

  <div>
    <label>Image (Optional)</label>
    <%= form.file_field :image %>
  </div>

  <div>
    <%= form.submit "Save Entry" %>
  </div>
<% end %>

<a href="/">Back to Places</a>
